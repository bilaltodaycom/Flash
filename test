                </ul>
            </div>

            <!-- Game Selection (Host only) -->
            <div class="glass-panel p-6 flex-1 flex flex-col slide-in border-t-2 border-[var(--neon-pink)]" style="animation-delay: 0.1s">
                <h3 class="text-2xl font-bold mb-6 flex items-center gap-3">
                    <i class="fa-solid fa-gamepad text-[var(--neon-pink)]"></i> Spiel wählen
