    <!-- 4️⃣ GAME: IMPOSTER -->
    <div id="game-imposter" class="hidden w-full max-w-6xl px-4 py-6 flex-col items-center h-full relative">
        <button onclick="backToLobby()" class="absolute top-4 left-4 text-gray-400 hover:text-white z-10 hidden-if-not-host bg-black bg-opacity-50 px-4 py-2 rounded-lg border border-gray-700"><i class="fa-solid fa-stop mr-2"></i>Spiel abbrechen</button>
        
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-6 neon-text-purple slide-in uppercase tracking-widest mt-12 md:mt-0">Imposter</h2>
        
        <!-- Role Reveal Overlay -->
        <div id="imposter-role-reveal" class="absolute inset-0 z-30 flex items-center justify-center bg-black bg-opacity-90 backdrop-blur-md slide-in">
            <div class="text-center mb-8 absolute top-20 left-0 w-full animate-pulse">
                <p class="text-gray-400 uppercase tracking-widest text-sm">Geheimhaltung aktiv</p>
                <p class="text-white text-lg">Tippe auf die Karte, um deine Rolle zu sehen</p>
            </div>
            <div class="flip-container w-72 h-96" onclick="this.classList.toggle('flipped'); playSound('click')">
                <div class="flipper">
                    <div class="front bg-gradient-to-b from-gray-800 to-gray-900 border-2 border-[var(--neon-purple)] rounded-3xl flex flex-col items-center justify-center p-6 shadow-[0_0_40px_rgba(176,38,255,0.4)] cursor-pointer">
                        <i class="fa-solid fa-fingerprint text-7xl text-[var(--neon-purple)] mb-6 pulse-anim"></i>
                        <h3 class="text-2xl font-bold text-center text-white">Rolle enthüllen</h3>
                    </div>
