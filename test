    <!-- ========================================== -->
    <!-- JAVASCRIPT LOGIC -->
    <!-- ========================================== -->
    <script>
        /**
         * ==========================================
         * SUPABASE API SETUP ANLEITUNG FÜR DEN AUFTRAGGEBER
         * ==========================================
         * 1. Gehe zu https://supabase.com/ und logge dich ein/erstelle ein Projekt.
         * 2. Gehe in deinem Projekt links unten auf das Zahnrad (Project Settings).
         * 3. Klicke auf "API" in der linken Sidebar.
         * 4. Kopiere die "Project URL" und ersetze den Text 'YOUR_SUPABASE_URL_HERE' unten.
         * 5. Kopiere den "Project API keys" -> "anon / public" Key und ersetze 'YOUR_SUPABASE_ANON_KEY_HERE' unten.
         * * WICHTIG - KEINE DATENBANK TABELLEN NÖTIG!
         * Dieses Spiel nutzt "Supabase Realtime Broadcast & Presence".
         * Es speichert keine Daten dauerhaft in Tabellen, sondern sendet sie live zwischen Spielern.
         * Stelle nur sicher, dass in den Einstellungen unter "Realtime" keine generellen Blockaden aktiv sind (standardmäßig funktioniert es direkt).
         */
        const SUPABASE_URL = 'YOUR_SUPABASE_URL_HERE'; // <--- HIER DEINE URL EINTRAGEN (z.B. https://xyz.supabase.co)
        const SUPABASE_KEY = 'YOUR_SUPABASE_ANON_KEY_HERE'; // <--- HIER DEINEN ANON KEY EINTRAGEN
        
        let supabase = null;
        let channel = null;

        // Global State
        const state = {
            view: 'loading',
            player: {
                id: 'p_' + Math.random().toString(36).substr(2, 9),
                name: '',
                color: getRandomColor(),
                isHost: false,
                role: null, 
                score: 0,
                hasVoted: false
            },
            room: {
                id: null,
                players: [], 
                gameState: 'lobby'
            }
        };

        // Helpers
        function getRandomColor() {
            const colors = ['#b026ff', '#00f3ff', '#ff007f', '#ffaa00', '#00ffaa', '#ff3333'];
            return colors[Math.floor(Math.random() * colors.length)];
        }
        function getInitials(name) {
            return name.substring(0, 2).toUpperCase();
        }

        // Game Data Dictionaries
        const DATA = {
            fakefact: [
                { q: "Erdbeeren sind keine Beeren, aber Bananen schon.", a: "fact" },
                { q: "Ein Tag auf der Venus ist länger als ein Jahr auf der Venus.", a: "fact" },
                { q: "Napoleon Bonaparte war extrem klein für seine Zeit.", a: "fake" },
                { q: "Oktopusse haben drei Herzen.", a: "fact" },
                { q: "Die Chinesische Mauer ist aus dem Weltraum mit bloßem Auge sichtbar.", a: "fake" },
                { q: "Honig verdirbt niemals, man kann 3000 Jahre alten Honig essen.", a: "fact" },
                { q: "Goldfische haben ein Gedächtnis von nur 3 Sekunden.", a: "fake" },
                { q: "Menschen nutzen nur 10% ihres Gehirns.", a: "fake" },
                { q: "Wassermelonen bestehen zu 92% aus Wasser.", a: "fact" },
                { q: "Stiere werden wütend, wenn sie die Farbe Rot sehen.", a: "fake" } // Sie sind farbenblind
            ],
            questions: [
                "Wenn du morgen mit einer neuen Fähigkeit aufwachen könntest, welche wäre es?",
                "Was war das Peinlichste, das dir in letzter Zeit passiert ist?",
                "Welche ungeschriebene Regel sollte jeder befolgen?",
                "Was ist eine Sache, die du bis heute nicht verstanden hast?",
                "Wenn dein Leben ein Film wäre, welches Genre wäre es?",
                "Was ist die dümmste Art, wie du dich jemals verletzt hast?",
                "Welches Geheimnis hast du noch nie jemandem erzählt? (Bleib sicher!)",
                "Was ist das Netteste, das jemals jemand für dich getan hat?",
                "Wenn du für einen Tag unsichtbar wärst, was würdest du tun?"
            ]
        };

        // Audio Context for Beeps
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        let audioCtx;
        function playSound(type) {
            try {
                if(!audioCtx) audioCtx = new AudioContext();
                if(audioCtx.state === 'suspended') audioCtx.resume();
                
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                if (type === 'click') {
                    osc.type = 'sine'; osc.frequency.setValueAtTime(600, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(800, audioCtx.currentTime + 0.05);
                    gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.05);
                } else if (type === 'success') {
                    osc.type = 'triangle'; osc.frequency.setValueAtTime(400, audioCtx.currentTime);
                    osc.frequency.setValueAtTime(600, audioCtx.currentTime + 0.1);
                    osc.frequency.setValueAtTime(800, audioCtx.currentTime + 0.2);
                    gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.4);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.4);
                } else if (type === 'error') {
                    osc.type = 'sawtooth'; osc.frequency.setValueAtTime(300, audioCtx.currentTime);
                    osc.frequency.setValueAtTime(150, audioCtx.currentTime + 0.2);
                    gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.4);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.4);
                } else if (type === 'vote') {
                    osc.type = 'square'; osc.frequency.setValueAtTime(200, audioCtx.currentTime);
                    gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.1);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.1);
                }
            } catch(e) { console.warn("Audio error", e); }
        }

        // Initialize App
        window.onload = () => {
            initCanvasBackground();
            
            // Try init Supabase safely
            try {
                if (SUPABASE_URL !== 'YOUR_SUPABASE_URL_HERE' && SUPABASE_KEY !== 'YOUR_SUPABASE_ANON_KEY_HERE') {
                    supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
                } else {
                    console.log("Supabase Keys not set. App will run in limited/mock mode if possible.");
                }
            } catch(e) {
                console.error("Supabase Init Failed", e);
            }

            // Safe Loading Screen Transition
            setTimeout(() => {
                const loader = document.getElementById('loading-screen');
                loader.style.opacity = '0';
                setTimeout(() => {
                    loader.classList.add('hidden');
                    switchView('main-menu');
                }, 800); // match css transition
            }, 2500);
        };

        function switchView(viewId) {
            ['loading-screen', 'main-menu', 'lobby-screen', 'game-imposter', 'game-fakefact', 'game-questions'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
            });
            document.getElementById(viewId).classList.remove('hidden');
            state.view = viewId;
            updateHostUI();
            playSound('click');
        }

        function updateHostUI() {
            const hostEls = document.querySelectorAll('.hidden-if-not-host');
            hostEls.forEach(el => { el.style.display = state.player.isHost ? '' : 'none'; });
            
            const waitMsg = document.getElementById('waiting-for-host-msg');
            if(waitMsg) waitMsg.style.display = state.player.isHost ? 'none' : 'flex';
        }

        // ==========================================
        // LOBBY & NETWORK
        // ==========================================

        function validateName() {
            const nameInput = document.getElementById('player-name-input').value.trim();
            if(!nameInput) {
                alert("Bitte gib einen Namen ein (oben rechts)!");
                document.getElementById('player-name-input').focus();
                return false;
            }
            state.player.name = nameInput;
            return true;
        }

        async function createRoomAction() {
            if(!validateName()) return;
            if(!supabase) { alert("Supabase API Keys fehlen im Code!"); return; }
            
            state.player.isHost = true;
            state.room.id = generateRoomCode();
            
            await joinSupabaseChannel(state.room.id);
            switchView('lobby-screen');
        }

        async function joinRoomAction() {
            if(!validateName()) return;
            if(!supabase) { alert("Supabase API Keys fehlen im Code!"); return; }

            const codeInput = document.getElementById('room-code-input').value.trim().toUpperCase();
            if(codeInput.length !== 4) {
                alert("Raumcode muss 4 Zeichen lang sein.");
                return;
            }

            state.player.isHost = false;
            state.room.id = codeInput;
            
            await joinSupabaseChannel(state.room.id);
            switchView('lobby-screen');
        }

        function copyRoomCode() {
            if(!state.room.id) return;
            navigator.clipboard.writeText(state.room.id).then(() => {
                playSound('success');
                alert("Raumcode kopiert: " + state.room.id);
            });
        }

        async function joinSupabaseChannel(roomId) {
            document.getElementById('display-room-code').innerText = roomId;
            
            if(channel) await supabase.removeChannel(channel);

            channel = supabase.channel(`room_${roomId}`, {
                config: { presence: { key: state.player.id } }
            });

            // Presence (Player List)
            channel.on('presence', { event: 'sync' }, () => {
                const newState = channel.presenceState();
                state.room.players = [];
                for (const id in newState) {
                    state.room.players.push(newState[id][0]);
                }
                updateLobbyUI();
                if(state.view === 'game-imposter') updateImposterPlayerGrid();
            });

            // Broadcasts (Events)
            channel.on('broadcast', { event: 'game_event' }, payload => {
                handleNetworkEvent(payload.payload);
            });

            channel.subscribe(async (status) => {
                if (status === 'SUBSCRIBED') {
                    await channel.track({
                        id: state.player.id,
                        name: state.player.name,
                        color: state.player.color,
                        isHost: state.player.isHost,
                        score: 0
                    });
                }
            });
        }

        function broadcastEvent(type, data = {}) {
            if(!channel) return;
            channel.send({
                type: 'broadcast',
                event: 'game_event',
                payload: { type, sender: state.player.id, ...data }
            });
        }

        function handleNetworkEvent(data) {
            switch(data.type) {
                case 'start_game': startGameUI(data.gameType); break;
                case 'back_to_lobby': switchView('lobby-screen'); break;
                
                // Imposter
                case 'imp_assign_roles':
                    state.player.role = data.roles[state.player.id];
                    showImposterRoleScreen(state.player.role);
                    break;
                case 'imp_chat': appendChatMessage(data.senderName, data.color, data.msg); break;
                case 'imp_player_voted': markPlayerVoted(data.sender); break;
                case 'imp_vote_result': showImposterResult(data.kickedName, data.wasImposter); break;

                // Fake Fact
                case 'ff_new_question': startFFRoundUI(data.question, data.round); break;
                case 'ff_reveal_answer': showFFResult(data.answer); break;

                // Questions
                case 'q_new_question': startQuestionRoundUI(data.question); break;
                case 'q_submit_answer': appendQuestionAnswer(data.senderName, data.color, data.answer); break;
            }
        }

        function leaveLobby() {
            if(channel) supabase.removeChannel(channel);
            state.room.id = null;
            state.room.players = [];
            switchView('main-menu');
        }

        function backToLobby() {
            if(state.player.isHost) broadcastEvent('back_to_lobby');
            switchView('lobby-screen');
        }

        function updateLobbyUI() {
            const list = document.getElementById('player-list');
            document.getElementById('player-count').innerText = `${state.room.players.length} / 12`;
            list.innerHTML = '';
            
            state.room.players.forEach(p => {
                const li = document.createElement('li');
                li.className = 'glass-panel p-3 flex justify-between items-center slide-in bg-opacity-40 hover:bg-opacity-60 transition';
                li.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="avatar" style="background-color: ${p.color}; border-color: ${p.id === state.player.id ? 'white' : 'transparent'}">
                            ${getInitials(p.name)}
                        </div>
                        <span class="font-bold text-lg ${p.id === state.player.id ? 'text-white' : 'text-gray-300'}">
                            ${p.name} ${p.id === state.player.id ? '(Du)' : ''}
                        </span>
                    </div>
                    ${p.isHost ? '<i class="fa-solid fa-crown text-yellow-400 text-xl" title="Host"></i>' : ''}
                `;
                list.appendChild(li);
            });
        }

        function generateRoomCode() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; // removed confusing chars
            let result = '';
            for (let i = 0; i < 4; i++) result += chars.charAt(Math.floor(Math.random() * chars.length));
            return result;
        }

        // ==========================================
        // GAMES CORE ROUTING
        // ==========================================
        function hostStartGame(gameType) {
            if(!state.player.isHost) return;
            broadcastEvent('start_game', { gameType });
            startGameUI(gameType);

            setTimeout(() => {
                if(gameType === 'imposter') hostInitImposter();
                if(gameType === 'fakefact') hostInitFF();
                if(gameType === 'questions') hostInitQuestions();
            }, 800); 
        }

        function startGameUI(gameType) {
            if(gameType === 'imposter') {
                switchView('game-imposter');
                document.getElementById('imposter-result').classList.add('hidden');
                document.getElementById('imposter-role-reveal').classList.remove('hidden');
                document.getElementById('imposter-game-area').classList.add('hidden');
                document.getElementById('imposter-role-reveal').querySelector('.flip-container').classList.remove('flipped');
                document.getElementById('imposter-chat').innerHTML = '';
                state.player.hasVoted = false;
            }
            else if(gameType === 'fakefact') {
                switchView('game-fakefact');
                state.player.score = 0;
                document.getElementById('ff-my-score').innerText = '0';
                document.getElementById('ff-card-result').classList.add('hidden');
                document.getElementById('btn-ff-next').classList.add('hidden');
            }
            else if(gameType === 'questions') {
                switchView('game-questions');
                document.getElementById('q-answers-list').innerHTML = '';
                document.getElementById('q-input-area').classList.add('hidden');
                document.getElementById('btn-q-next').classList.add('hidden');
            }
        }


        // ==========================================
        // GAME 1: IMPOSTER
        // ==========================================
        function hostInitImposter() {
            const players = [...state.room.players];
            const imposterIndex = Math.floor(Math.random() * players.length);
            const roles = {};
            players.forEach((p, idx) => { roles[p.id] = (idx === imposterIndex) ? 'imposter' : 'crewmate'; });
            broadcastEvent('imp_assign_roles', { roles });
        }

        function showImposterRoleScreen(role) {
            const icon = document.getElementById('imposter-role-icon');
            const title = document.getElementById('imposter-role-title');
            const desc = document.getElementById('imposter-role-desc');
            const back = document.querySelector('#imposter-role-reveal .back');

            if(role === 'imposter') {
                icon.className = 'fa-solid fa-user-secret text-8xl text-[var(--neon-pink)] mb-6 drop-shadow-lg';
                title.innerText = 'Imposter';
                title.className = 'text-5xl font-extrabold mb-3 uppercase tracking-wider neon-text-pink text-[var(--neon-pink)]';
                desc.innerText = 'Täusche die anderen und werde nicht erwischt!';
                back.style.borderColor = 'var(--neon-pink)';
            } else {
                icon.className = 'fa-solid fa-user-astronaut text-8xl text-[var(--neon-blue)] mb-6 drop-shadow-lg';
                title.innerText = 'Crewmate';
                title.className = 'text-5xl font-extrabold mb-3 uppercase tracking-wider neon-text-blue text-[var(--neon-blue)]';
                desc.innerText = 'Finde den Verräter durch Diskussion!';
                back.style.borderColor = 'var(--neon-blue)';
            }
        }

        function closeRoleReveal(e) {
            e.stopPropagation();
            document.getElementById('imposter-role-reveal').classList.add('hidden');
            document.getElementById('imposter-game-area').classList.remove('hidden');
            updateImposterPlayerGrid();
        }

        function updateImposterPlayerGrid() {
            if(state.view !== 'game-imposter') return;
            const grid = document.getElementById('imposter-player-grid');
            grid.innerHTML = '';
            
            state.room.players.forEach(p => {
                const btn = document.createElement('button');
                btn.id = `imp-btn-${p.id}`;
                btn.className = 'glass-panel p-4 flex flex-col items-center justify-center gap-3 hover:bg-white hover:bg-opacity-10 transition focus:outline-none rounded-2xl border-2 border-transparent relative overflow-hidden group';
                btn.innerHTML = `
                    <div class="avatar w-14 h-14 text-xl border-4" style="background-color: ${p.color}; border-color: rgba(255,255,255,0.2)">
                        ${getInitials(p.name)}
                    </div>
                    <span class="font-bold text-sm truncate w-full text-center text-white">${p.name}</span>
                    <div id="voted-icon-${p.id}" class="absolute top-2 right-2 text-green-400 hidden"><i class="fa-solid fa-check-circle"></i></div>
                `;
                btn.onclick = () => selectImposterVote(p.id, btn);
                grid.appendChild(btn);
            });
        }

        let selectedVoteId = null;
        function selectImposterVote(id, btnEl) {
            if(state.player.hasVoted) return;
            playSound('click');
            selectedVoteId = id;
            document.querySelectorAll('#imposter-player-grid button').forEach(b => b.classList.remove('border-[var(--neon-purple)]', 'bg-white', 'bg-opacity-10'));
            btnEl.classList.add('border-[var(--neon-purple)]', 'bg-white', 'bg-opacity-10');
            document.getElementById('btn-imposter-vote').disabled = false;
            document.getElementById('btn-imposter-vote').classList.remove('hidden');
        }

        function submitImposterVote() {
            if(!selectedVoteId || state.player.hasVoted) return;
            state.player.hasVoted = true;
            
            const btn = document.getElementById('btn-imposter-vote');
            btn.innerText = "Vote eingeloggt";
            btn.disabled = true;
            btn.classList.replace('purple', 'blue');
            playSound('vote');

            broadcastEvent('imp_player_voted');
            markPlayerVoted(state.player.id);
            
            // FAKE LOGIC FOR DEMO: Host decides result immediately for speed.
            // In real app, Host tallies votes and waits for all.
            if(state.player.isHost) {
                setTimeout(() => {
                    const targetPlayer = state.room.players.find(p => p.id === selectedVoteId);
                    const wasImposter = true; // Random mock
                    broadcastEvent('imp_vote_result', { kickedName: targetPlayer.name, wasImposter: wasImposter });
                    showImposterResult(targetPlayer.name, wasImposter);
                }, 2000);
            }
        }

        function markPlayerVoted(id) {
            const icon = document.getElementById(`voted-icon-${id}`);
            if(icon) icon.classList.remove('hidden');
        }

        function showImposterResult(kickedName, wasImposter) {
            const resEl = document.getElementById('imposter-result');
            const icon = document.getElementById('imp-result-icon');
            const title = document.getElementById('imposter-result-title');
            const desc = document.getElementById('imposter-result-desc');
            resEl.classList.remove('hidden');

            if(wasImposter) {
                icon.innerHTML = '<i class="fa-solid fa-trophy text-[var(--neon-blue)]"></i>';
                title.innerText = "Crewmates Gewinnen!";
                title.className = "text-5xl md:text-7xl font-extrabold mb-4 uppercase neon-text-blue text-[var(--neon-blue)]";
                desc.innerText = `${kickedName} war der Imposter.`;
                playSound('success');
            } else {
                icon.innerHTML = '<i class="fa-solid fa-skull text-[var(--neon-pink)]"></i>';
                title.innerText = "Imposter Gewinnt!";
                title.className = "text-5xl md:text-7xl font-extrabold mb-4 uppercase neon-text-pink text-[var(--neon-pink)]";
                desc.innerText = `${kickedName} war ein unschuldiger Crewmate.`;
                playSound('error');
            }
        }

        function sendChatMessage() {
            const input = document.getElementById('imposter-chat-input');
            const msg = input.value.trim();
            if(!msg) return;
            
            broadcastEvent('imp_chat', { senderName: state.player.name, color: state.player.color, msg: msg });
            input.value = '';
            appendChatMessage(state.player.name, state.player.color, msg);
        }

        function appendChatMessage(name, color, msg) {
            const chatBox = document.getElementById('imposter-chat');
            const div = document.createElement('div');
            const isMe = name === state.player.name;
            div.className = `flex flex-col mb-2 ${isMe ? 'items-end' : 'items-start'}`;
            div.innerHTML = `
                <span class="text-xs mb-1 font-bold" style="color: ${color}">${name}</span>
                <div class="px-4 py-2 rounded-2xl max-w-[80%] ${isMe ? 'bg-[var(--neon-blue)] text-black rounded-tr-none' : 'bg-gray-800 text-white rounded-tl-none'}">
                    ${msg}
                </div>
            `;
            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        }


        // ==========================================
        // GAME 2: FAKE OR FACT
        // ==========================================
        let ffCurrentRound = 0;
        let ffCurrentQuestion = null;

        function hostInitFF() {
            ffCurrentRound = 0;
            state.room.players.forEach(p => p.score = 0);
            hostNextFFRound();
        }

        function hostNextFFRound() {
            ffCurrentRound++;
            if(ffCurrentRound > 5) {
                alert("Spiel vorbei! Schau auf die Punkte.");
                backToLobby();
                return;
            }
            
            const qObj = DATA.fakefact[Math.floor(Math.random() * DATA.fakefact.length)];
            ffCurrentQuestion = qObj;
            
            broadcastEvent('ff_new_question', { question: qObj.q, round: ffCurrentRound });
            startFFRoundUI(qObj.q, ffCurrentRound);
            
            setTimeout(() => {
                broadcastEvent('ff_reveal_answer', { answer: qObj.a });
                showFFResult(qObj.a);
            }, 8000); // 8 seconds to answer
        }

        function startFFRoundUI(questionText, round) {
            document.getElementById('ff-round-counter').innerText = `${round}/5`;
            document.getElementById('ff-question-text').innerText = questionText;
            document.getElementById('ff-status-text').innerText = "WAHR ODER FALSCH?";
            document.getElementById('ff-status-text').className = "text-[var(--neon-purple)] font-bold tracking-[0.2em] mb-8 animate-pulse text-sm bg-purple-900 bg-opacity-30 px-4 py-1 rounded-full border border-purple-500";
            
            document.getElementById('btn-ff-fake').disabled = false;
            document.getElementById('btn-ff-fact').disabled = false;
            document.getElementById('ff-card-result').classList.add('hidden');
            if(state.player.isHost) document.getElementById('btn-ff-next').classList.add('hidden');

            const bar = document.getElementById('ff-timer-bar');
            bar.style.transition = 'none';
            bar.style.width = '100%';
            setTimeout(() => {
                bar.style.transition = 'width 8s linear';
                bar.style.width = '0%';
            }, 50);
        }

        function submitFFVote(vote) {
            playSound('click');
            document.getElementById('btn-ff-fake').disabled = true;
            document.getElementById('btn-ff-fact').disabled = true;
            
            const status = document.getElementById('ff-status-text');
            status.innerText = "EINGELOGGT!";
            status.className = "text-white font-bold tracking-[0.2em] mb-8 text-sm bg-gray-700 bg-opacity-50 px-4 py-1 rounded-full border border-gray-500";
            
            state.player.lastVoteFF = vote; 
        }

        function showFFResult(correctAnswer) {
            const gameContainer = document.getElementById('game-fakefact');
            const overlay = document.getElementById('ff-card-result');
            const icon = document.getElementById('ff-result-icon');
            const text = document.getElementById('ff-result-text');
            const subtext = document.getElementById('ff-result-subtext');
            
            overlay.classList.remove('hidden');
            const myVote = state.player.lastVoteFF;
            
            if(myVote === correctAnswer) {
                icon.className = 'fa-solid fa-circle-check text-green-400';
                text.innerText = "RICHTIG!";
                text.className = 'text-5xl md:text-7xl font-extrabold uppercase tracking-widest text-green-400';
                subtext.innerText = "+10 Punkte";
                state.player.score += 10;
                gameContainer.classList.add('flash-green');
                playSound('success');
            } else {
                icon.className = 'fa-solid fa-circle-xmark text-red-500';
                text.innerText = myVote ? "FALSCH!" : "ZU SPÄT!";
                text.className = 'text-5xl md:text-7xl font-extrabold uppercase tracking-widest text-red-500';
                subtext.innerText = "0 Punkte";
                gameContainer.classList.add('flash-red');
                playSound('error');
            }
            
            document.getElementById('ff-my-score').innerText = state.player.score;
            state.player.lastVoteFF = null; 

            if(state.player.isHost) document.getElementById('btn-ff-next').classList.remove('hidden');
        }


        // ==========================================
        // GAME 3: 100 QUESTIONS
        // ==========================================
        function hostInitQuestions() {
            hostNextQuestion();
        }

        function hostNextQuestion() {
            const q = DATA.questions[Math.floor(Math.random() * DATA.questions.length)];
            broadcastEvent('q_new_question', { question: q });
            startQuestionRoundUI(q);
        }

        function startQuestionRoundUI(q) {
            document.getElementById('q-question-text').innerText = q;
            document.getElementById('q-answers-list').innerHTML = '';
            document.getElementById('q-input-area').classList.remove('hidden');
            document.getElementById('q-answer-input').value = '';
            
            if(state.player.isHost) document.getElementById('btn-q-next').classList.remove('hidden');
        }

        function submitQAnswer() {
            const val = document.getElementById('q-answer-input').value.trim();
            if(!val) return;
            playSound('click');
            
            document.getElementById('q-input-area').classList.add('hidden');
            broadcastEvent('q_submit_answer', { senderName: state.player.name, color: state.player.color, answer: val });
            appendQuestionAnswer(state.player.name, state.player.color, val);
        }

        function appendQuestionAnswer(name, color, answer) {
            const list = document.getElementById('q-answers-list');
            const card = document.createElement('div');
            card.className = 'glass-panel p-5 slide-in border-l-4 relative overflow-hidden';
            card.style.borderLeftColor = color;
            card.innerHTML = `
                <div class="absolute top-0 right-0 w-16 h-16 rounded-full blur-2xl opacity-20" style="background-color: ${color}"></div>
                <div class="flex items-center gap-2 mb-3">
                    <div class="avatar w-8 h-8 text-xs border-2" style="background-color: ${color}; border-color: rgba(255,255,255,0.2)">
                        ${getInitials(name)}
                    </div>
                    <div class="text-sm font-bold text-gray-300 uppercase tracking-wide">${name}</div>
                </div>
                <div class="text-xl font-bold text-white leading-relaxed">${answer}</div>
            `;
            list.appendChild(card);
            playSound('click');
        }

        // ==========================================
        // VISUAL EFFECTS (Canvas Particles)
        // ==========================================
        function initCanvasBackground() {
            const canvas = document.getElementById('bg-canvas');
            const ctx = canvas.getContext('2d');
            let particles = [];

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
                initParticles();
            }

            function initParticles() {
                particles = [];
                for(let i=0; i<60; i++) {
                    particles.push({
                        x: Math.random() * canvas.width,
                        y: Math.random() * canvas.height,
                        radius: Math.random() * 2 + 0.5,
                        vx: (Math.random() - 0.5) * 0.4,
                        vy: (Math.random() - 0.5) * 0.4,
                        alpha: Math.random() * 0.5 + 0.1
                    });
                }
            }

            window.addEventListener('resize', resize);
            resize();

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                
                particles.forEach(p => {
                    p.x += p.vx;
                    p.y += p.vy;
                    
                    if(p.x < 0 || p.x > canvas.width) p.vx *= -1;
                    if(p.y < 0 || p.y > canvas.height) p.vy *= -1;

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(176, 38, 255, ${p.alpha})`; 
                    ctx.fill();
                });
                
                requestAnimationFrame(draw);
            }
            draw();
        }
    </script>
