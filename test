<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Flash | BilalToday.com</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Montserrat:wght@700;800&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Supabase JS -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --neon-purple: #b026ff;
            --neon-blue: #00f3ff;
            --neon-pink: #ff007f;
            --bg-dark: #07070a;
            --glass-bg: rgba(20, 20, 30, 0.5);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-dark);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }

        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .font-montserrat { font-family: 'Montserrat', sans-serif; }

        /* Background Animations */
        #bg-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            z-index: -2;
            background: radial-gradient(circle at 50% 50%, #101018 0%, var(--bg-dark) 100%);
        }

        .ambient-glow {
            position: fixed;
            border-radius: 50%;
            filter: blur(120px);
            z-index: -1;
            opacity: 0.3;
            animation: float 12s infinite alternate ease-in-out;
            pointer-events: none;
        }
        .glow-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: var(--neon-purple); animation-delay: 0s; }
        .glow-2 { bottom: -10%; right: -10%; width: 40vw; height: 40vw; background: var(--neon-blue); animation-delay: -6s; }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(60px, 60px) scale(1.1); }
        }

        /* Glassmorphism */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        /* Neon Text & Elements */
        .neon-text-purple { text-shadow: 0 0 10px var(--neon-purple), 0 0 25px var(--neon-purple); }
        .neon-text-blue { text-shadow: 0 0 10px var(--neon-blue), 0 0 25px var(--neon-blue); }
        .neon-text-pink { text-shadow: 0 0 10px var(--neon-pink), 0 0 25px var(--neon-pink); }
        
        .neon-box-blue { box-shadow: 0 0 15px var(--neon-blue), inset 0 0 10px var(--neon-blue); border-color: var(--neon-blue); }
        .neon-box-purple { box-shadow: 0 0 15px var(--neon-purple), inset 0 0 10px var(--neon-purple); border-color: var(--neon-purple); }
        .neon-box-pink { box-shadow: 0 0 15px var(--neon-pink), inset 0 0 10px var(--neon-pink); border-color: var(--neon-pink); }

        /* Branding Specific */
        .brand-glow {
            background: linear-gradient(90deg, var(--neon-blue), var(--neon-purple), var(--neon-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: textShine 4s linear infinite;
            background-size: 200% auto;
        }
        @keyframes textShine {
            to { background-position: 200% center; }
        }

        /* Buttons */
        .btn-neon {
            position: relative;
            background: rgba(0, 0, 0, 0.3);
            color: white;
            border: 2px solid var(--neon-blue);
            padding: 14px 28px;
            border-radius: 16px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            z-index: 1;
            cursor: pointer;
            backdrop-filter: blur(5px);
        }
        .btn-neon::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: var(--neon-blue);
            z-index: -1;
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            transform: scaleX(0);
            transform-origin: left;
        }
        .btn-neon:hover {
            box-shadow: 0 0 25px var(--neon-blue);
            color: var(--bg-dark);
            transform: translateY(-2px);
        }
        .btn-neon:hover::before { transform: scaleX(1); }
        .btn-neon:active { transform: translateY(1px); }

        .btn-neon.pink { border-color: var(--neon-pink); }
        .btn-neon.pink::before { background: var(--neon-pink); }
        .btn-neon.pink:hover { box-shadow: 0 0 25px var(--neon-pink); }

        .btn-neon.purple { border-color: var(--neon-purple); }
        .btn-neon.purple::before { background: var(--neon-purple); }
        .btn-neon.purple:hover { box-shadow: 0 0 25px var(--neon-purple); }

        .btn-neon:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            border-color: gray;
            box-shadow: none;
            transform: none;
        }
        .btn-neon:disabled::before { display: none; }

        /* 3D Card Flip */
        .flip-container {
            perspective: 1000px;
            cursor: pointer;
        }
        .flipper {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            transform-style: preserve-3d;
        }
        .flip-container:hover .flipper.hover-flip {
            transform: rotateY(180deg);
        }
        .flip-container.flipped .flipper {
            transform: rotateY(180deg);
        }
        .front, .back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 24px;
        }
        .back {
            transform: rotateY(180deg);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: rgba(20, 20, 30, 0.9);
            border: 1px solid var(--neon-purple);
            box-shadow: 0 0 30px rgba(176, 38, 255, 0.2);
        }

        /* Animations */
        .slide-in { animation: slideIn 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards; opacity: 0; }
        @keyframes slideIn {
            0% { transform: translateY(40px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }

        .pulse-anim { animation: pulseAnim 2s infinite; }
        @keyframes pulseAnim {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 243, 255, 0.4); }
            70% { transform: scale(1.05); box-shadow: 0 0 0 20px rgba(0, 243, 255, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 243, 255, 0); }
        }

        /* Screen Flashes */
        .flash-green { animation: flashGreen 0.5s ease-out; }
        @keyframes flashGreen {
            0% { box-shadow: inset 0 0 100px rgba(34, 197, 94, 0.8); }
            100% { box-shadow: inset 0 0 0px rgba(34, 197, 94, 0); }
        }
        .flash-red { animation: flashRed 0.5s ease-out; }
        @keyframes flashRed {
            0% { box-shadow: inset 0 0 100px rgba(239, 68, 68, 0.8); }
            100% { box-shadow: inset 0 0 0px rgba(239, 68, 68, 0); }
        }

        /* Loading Bar */
        .loading-bar-container {
            width: 280px;
            height: 8px;
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
            overflow: hidden;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.5);
        }
        .loading-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--neon-purple), var(--neon-blue), var(--neon-pink));
            animation: load 2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
            border-radius: 10px;
        }
        @keyframes load { 100% { width: 100%; } }

        /* Avatar Generator Styles */
        .avatar {
            width: 40px; height: 40px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: bold; color: white;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
            border: 2px solid rgba(255,255,255,0.2);
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--neon-purple); border-radius: 10px; }

        .hidden { display: none !important; }

        /* Fixed Branding Overlay */
        .branding-fixed { 
            position: fixed; 
            bottom: 20px; right: 20px; 
            z-index: 100; 
            pointer-events: none;
            background: rgba(0,0,0,0.6);
            padding: 8px 16px;
            border-radius: 30px;
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            transition: 0.3s;
        }
        .branding-fixed:hover { border-color: var(--neon-pink); }
    </style>
</head>
<body class="antialiased h-screen w-screen flex flex-col items-center justify-center relative">

    <!-- Background -->
    <canvas id="bg-canvas"></canvas>
    <div class="ambient-glow glow-1"></div>
    <div class="ambient-glow glow-2"></div>

    <!-- 🌟 Global Premium Branding -->
    <div class="branding-fixed flex items-center gap-2">
        <i class="fa-solid fa-bolt text-[var(--neon-blue)]"></i>
        <span class="brand-glow text-sm">BilalToday.com</span>
    </div>

    <!-- 1️⃣ LOADING SCREEN -->
    <div id="loading-screen" class="absolute inset-0 flex flex-col items-center justify-center z-50 bg-[var(--bg-dark)] transition-opacity duration-700">
        <div class="text-center mb-10">
            <div class="relative inline-block mb-6">
                <i class="fa-solid fa-bolt text-7xl text-[var(--neon-blue)] neon-text-blue pulse-anim"></i>
                <div class="absolute inset-0 bg-[var(--neon-purple)] blur-2xl opacity-40 rounded-full"></div>
            </div>
            <h1 class="text-7xl font-montserrat font-extrabold tracking-tighter text-white mb-2 uppercase drop-shadow-2xl">
                Fla<span class="text-[var(--neon-purple)] neon-text-purple">sh</span>
            </h1>
            <p class="text-[var(--neon-pink)] tracking-[0.3em] text-xs font-bold uppercase mt-2">Partyspiele mit Freunden</p>
        </div>
        <div class="loading-bar-container mt-4">
            <div class="loading-bar"></div>
        </div>
        <div class="mt-12 text-sm text-gray-500 flex items-center gap-2">
            <i class="fa-solid fa-code"></i> by <span class="text-white font-bold tracking-wider">BilalToday.com</span>
        </div>
    </div>

    <!-- 2️⃣ MAIN MENU -->
    <div id="main-menu" class="hidden w-full max-w-6xl px-4 py-8 flex flex-col items-center h-full overflow-y-auto">
        <header class="w-full flex justify-between items-center py-4 slide-in mb-6">
            <h2 class="text-4xl font-montserrat font-bold">Fla<span class="text-[var(--neon-purple)]">sh</span></h2>
            
            <div class="flex items-center gap-3 glass-panel px-2 py-1 rounded-full">
                <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-[var(--neon-blue)] to-[var(--neon-purple)] flex items-center justify-center border-2 border-white">
                    <i class="fa-solid fa-user text-white text-sm"></i>
                </div>
                <input type="text" id="player-name-input" placeholder="Dein Name" class="bg-transparent text-white font-bold outline-none w-28 md:w-40 placeholder-gray-400" autocomplete="off" maxlength="12">
            </div>
        </header>

        <!-- Room Actions -->
        <div class="glass-panel p-8 w-full max-w-lg mx-auto text-center slide-in mb-12 border-t-4 border-t-[var(--neon-blue)]" style="animation-delay: 0.1s">
            <h3 class="text-2xl font-bold mb-6 text-white tracking-wide">Multiplayer Lobby</h3>
            <div class="flex gap-3 justify-center mb-8 relative">
                <input type="text" id="room-code-input" placeholder="CODE (z.B. AB12)" class="bg-black bg-opacity-50 border border-gray-600 rounded-xl px-4 py-4 w-1/2 text-center text-2xl font-mono uppercase outline-none focus:border-[var(--neon-purple)] transition-colors" maxlength="4">
                <button onclick="joinRoomAction()" class="btn-neon purple flex-1 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-right-to-bracket"></i> Beitreten
                </button>
            </div>
            
            <div class="relative flex py-2 items-center mb-6">
                <div class="flex-grow border-t border-gray-700"></div>
                <span class="flex-shrink-0 mx-4 text-gray-500 text-sm font-bold uppercase tracking-widest">Oder</span>
                <div class="flex-grow border-t border-gray-700"></div>
            </div>
            
            <button onclick="createRoomAction()" class="btn-neon blue w-full py-5 text-lg shadow-[0_0_20px_rgba(0,243,255,0.2)] hover:shadow-[0_0_30px_rgba(0,243,255,0.6)]">
                <i class="fa-solid fa-plus-circle mr-2"></i> Neue Lobby erstellen
            </button>
        </div>

        <!-- Games Grid -->
        <h3 class="text-sm text-gray-400 uppercase tracking-[0.2em] mb-6 text-center slide-in font-bold" style="animation-delay: 0.2s">Unsere Spiele</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full slide-in px-4" style="animation-delay: 0.3s">
            <!-- Game 1 -->
            <div class="flip-container h-72">
                <div class="flipper hover-flip glass-panel">
                    <div class="front flex flex-col items-center justify-center p-6 text-center relative overflow-hidden">
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--neon-purple)] rounded-full blur-3xl opacity-20"></div>
                        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-purple-600 to-blue-600 flex items-center justify-center mb-4 shadow-lg border border-purple-400">
                            <i class="fa-solid fa-user-secret text-4xl text-white"></i>
                        </div>
                        <h3 class="text-2xl font-bold mb-2 tracking-wide">Imposter</h3>
                        <p class="text-gray-400 text-sm">Wer lügt? Finde den Verräter am Tisch.</p>
                        <div class="mt-4 px-3 py-1 bg-purple-900 bg-opacity-50 rounded-full text-xs font-bold text-purple-300">3-12 Spieler</div>
                    </div>
                    <div class="back p-6 text-center">
                        <i class="fa-solid fa-gamepad text-4xl text-[var(--neon-purple)] mb-4"></i>
                        <p class="font-bold">Lobby erstellen, um zu spielen!</p>
                    </div>
                </div>
            </div>
            <!-- Game 2 -->
            <div class="flip-container h-72">
                <div class="flipper hover-flip glass-panel">
                    <div class="front flex flex-col items-center justify-center p-6 text-center relative overflow-hidden">
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--neon-blue)] rounded-full blur-3xl opacity-20"></div>
                        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-cyan-500 to-blue-700 flex items-center justify-center mb-4 shadow-lg border border-cyan-400">
                            <i class="fa-solid fa-check-double text-4xl text-white"></i>
                        </div>
                        <h3 class="text-2xl font-bold mb-2 tracking-wide">Fake or Fact</h3>
                        <p class="text-gray-400 text-sm">Teste dein Wissen mit verrückten Fakten.</p>
                        <div class="mt-4 px-3 py-1 bg-blue-900 bg-opacity-50 rounded-full text-xs font-bold text-blue-300">2+ Spieler</div>
                    </div>
                    <div class="back p-6 text-center">
                        <i class="fa-solid fa-gamepad text-4xl text-[var(--neon-blue)] mb-4"></i>
                        <p class="font-bold">Lobby erstellen, um zu spielen!</p>
                    </div>
                </div>
            </div>
            <!-- Game 3 -->
            <div class="flip-container h-72">
                <div class="flipper hover-flip glass-panel">
                    <div class="front flex flex-col items-center justify-center p-6 text-center relative overflow-hidden">
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--neon-pink)] rounded-full blur-3xl opacity-20"></div>
                        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-pink-500 to-rose-700 flex items-center justify-center mb-4 shadow-lg border border-pink-400">
                            <i class="fa-solid fa-comments text-4xl text-white"></i>
                        </div>
                        <h3 class="text-2xl font-bold mb-2 tracking-wide">100 Questions</h3>
                        <p class="text-gray-400 text-sm">Deep Talk & Lustige Fragen für die Crew.</p>
                        <div class="mt-4 px-3 py-1 bg-pink-900 bg-opacity-50 rounded-full text-xs font-bold text-pink-300">2+ Spieler</div>
                    </div>
                    <div class="back p-6 text-center">
                        <i class="fa-solid fa-gamepad text-4xl text-[var(--neon-pink)] mb-4"></i>
                        <p class="font-bold">Lobby erstellen, um zu spielen!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3️⃣ LOBBY SCREEN -->
    <div id="lobby-screen" class="hidden w-full max-w-5xl px-4 py-6 flex-col items-center h-full">
        <header class="w-full flex justify-between items-center py-4 mb-4 border-b border-gray-800">
            <button onclick="leaveLobby()" class="text-gray-400 hover:text-white transition flex items-center gap-2 bg-gray-900 px-4 py-2 rounded-lg">
                <i class="fa-solid fa-arrow-left"></i> Verlassen
            </button>
            <div class="text-center group cursor-pointer" onclick="copyRoomCode()" title="Code kopieren">
                <p class="text-xs uppercase tracking-widest text-gray-500 mb-1">Raumcode (Klicken zum Kopieren)</p>
                <div class="flex items-center justify-center gap-3">
                    <h2 id="display-room-code" class="text-5xl font-mono font-bold neon-text-purple tracking-[0.2em] uppercase text-white">----</h2>
                    <i class="fa-solid fa-copy text-gray-600 group-hover:text-[var(--neon-purple)] transition"></i>
                </div>
            </div>
            <div class="w-28"></div> <!-- Spacer for flex balance -->
        </header>

        <div class="flex flex-col lg:flex-row gap-6 w-full h-[75vh]">
            <!-- Player List -->
            <div class="glass-panel p-6 flex-1 flex flex-col slide-in border-t-2 border-[var(--neon-blue)]">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-2xl font-bold flex items-center gap-3">
                        <i class="fa-solid fa-users text-[var(--neon-blue)]"></i> Spieler
                    </h3>
                    <span class="bg-[var(--neon-blue)] bg-opacity-20 text-[var(--neon-blue)] px-3 py-1 rounded-full font-bold text-sm" id="player-count">1 / 12</span>
                </div>
